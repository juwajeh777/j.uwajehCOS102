    "PSEUDOCODE FOR STORE CHECKOUT PROCESS\n",
    "BEGIN\n",
    "GET Barcode\n",
    "INPUT Goods\n",
    "COMPUTE Goods Price * Quantity\n",
    "DISPLAY Total Price\n",
    "GET Credit card or Debit Card\n",
    "INPUT Card Pin\n",
    "PRINT receipt\n",
    "END.\n"
